{
  "name": "@pi-ext/permission-modes",
  "version": "0.0.1",
  "description": "Pi extension: Claude-Code-style permission modes (Shift+Tab) with a merged allow/deny/ask rule engine",
  "keywords": [
    "permission-modes",
    "permissions",
    "pi-extension",
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./controller": "./src/controller.ts",
    "./engine": "./src/rules/engine.ts",
    "./scope": "./src/scope.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "tree-sitter-bash": "0.25.1",
    "web-tree-sitter": "0.26.9"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
