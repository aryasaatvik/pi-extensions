{
  "name": "@pi-ext/web",
  "version": "0.0.1",
  "description": "Pi extension: vendor-agnostic web_search and web_fetch",
  "keywords": [
    "exa",
    "pi-extension",
    "pi-package",
    "web-search"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "effect": "catalog:",
    "exa-js": "^2.8.0",
    "parallel-web": "^0.5.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "catalog:pi",
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "typebox": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "catalog:pi",
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
