{
  "name": "@pi-ext/ask",
  "version": "0.0.1",
  "description": "Pi extension: an `ask` tool that lets the model ask the user multiple-choice questions (mirrors Claude Code's AskUserQuestion)",
  "keywords": [
    "ask",
    "askuserquestion",
    "pi-extension",
    "pi-package",
    "questions"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "@pi-ext/ui": "workspace:*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "@types/node": "catalog:",
    "typebox": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
