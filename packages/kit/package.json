{
  "name": "@pi-ext/kit",
  "version": "0.0.1",
  "description": "Pi extension preset: installs the ask tool and permission modes together in one package",
  "keywords": [
    "pi-extension",
    "pi-package",
    "preset"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "@pi-ext/ask": "workspace:*",
    "@pi-ext/permission-modes": "workspace:*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "catalog:pi",
    "@earendil-works/pi-tui": "catalog:pi"
  },
  "pi": {
    "extensions": [
      "./src/ask.ts",
      "./src/permission-modes.ts"
    ]
  }
}
